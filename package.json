{
  "name": "appvault",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "db:migrate": "npm run prisma:migrate -w backend",
    "db:studio": "npm run prisma:studio -w backend",
    "db:seed": "npm run seed -w backend",
    "test": "npm run test -w backend"
  },
  "devDependencies": {
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "unicode-match-property-value-ecmascript": "^2.2.0"
  }
}
